{
  "name": "setup-mesa-dist-win",
  "version": "3.0.0",
  "description": "Installs Mesa3D from https://github.com/pal1000/mesa-dist-win/",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "package": "rimraf ./dist && rollup --config rollup.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssciwr/setup-mesa-dist-win.git"
  },
  "keywords": [
    "Mesa3D",
    "opengl",
    "mesa-dist-win"
  ],
  "author": "Liam Keegan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ssciwr/setup-mesa-dist-win/issues"
  },
  "homepage": "https://github.com/ssciwr/setup-mesa-dist-win#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rimraf": "^6.0.1",
    "rollup": "^4.57.1"
  }
}
